generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model GiftCard {
  id            String         @id @default(cuid())
  code          String         @unique
  recipientName String
  amount        String
  isProduct     Boolean        @default(false)
  date          String
  status        GiftCardStatus @default(ACTIVE)
  createdAt     DateTime       @default(now())
  usedAt        DateTime?
  notes         String?
}

enum GiftCardStatus {
  ACTIVE
  USED
  CANCELLED
}
